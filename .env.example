NEXT_PUBLIC_ADMIN_EMAIL=seu@email.com

# Opcional — intervalo do cron LOCAL em minutos (padrão: 15)
# Use: CRON_INTERVAL_MIN=1 npm run cron
CRON_INTERVAL_MIN=15
